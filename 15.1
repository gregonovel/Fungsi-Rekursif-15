def cek_prima(n, i=2):
    # Base Cases
    if n <= 2:
        return True if n == 2 else False
    if n % i == 0:
        return False
    if i * i > n:
        return True
    # Recursive Case
    return cek_prima(n, i + 1)

print(cek_prima(11))  # Output: True
print(cek_prima(4))   # Output: False
